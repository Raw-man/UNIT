#pragma once

#define UNIT_STR_HELPER(x) #x
#define UNIT_STR(x) UNIT_STR_HELPER(x)


#define UNIT_VERSION_MAJOR @unit_VERSION_MAJOR@
#define UNIT_VERSION_MINOR @unit_VERSION_MINOR@
#define UNIT_VERSION_PATCH @unit_VERSION_PATCH@

#define UNIT_VERSION_STR UNIT_STR(UNIT_VERSION_MAJOR) "." UNIT_STR(UNIT_VERSION_MINOR) "." UNIT_STR(UNIT_VERSION_PATCH)

#define UNIT_GIT_HASH "@GIT_COMMIT_HASH@"

#define UNIT_BUILD_STR "ver " UNIT_VERSION_STR  " " UNIT_BUILD_TYPE " " __DATE__ " " UNIT_GIT_HASH
